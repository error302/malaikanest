[Unit]
Description=Malaika Nest healthcheck
After=docker.service

[Service]
Type=oneshot
User=ubuntu
# Set REPO_DIR and NOTIFY_WEBHOOK when enabling or via /etc/default/malaika_nest
Environment=REPO_DIR=/home/ubuntu/malaika_nest
Environment=NOTIFY_WEBHOOK=
WorkingDirectory=${REPO_DIR}
ExecStart=/bin/bash ${REPO_DIR}/deployment/healthcheck.sh
Nice=10
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
