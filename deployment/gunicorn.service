[Unit]
Description=gunicorn daemon for kenya_baby_ecommerce
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/kenya_baby_ecommerce/backend
ExecStart=/usr/bin/gunicorn --access-logfile - --workers 4 --bind unix:/run/gunicorn.sock kenya_ecom.wsgi:application
Restart=always

[Install]
WantedBy=multi-user.target
