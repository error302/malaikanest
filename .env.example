# ============================================
# MALAIKA NEST ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values

# ------------------------------
# DJANGO SETTINGS
# ------------------------------
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,malaikanest.duckdns.org

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/malaikanest

# ------------------------------
# JWT AUTHENTICATION
# ------------------------------
JWT_SIGNING_KEY=your-jwt-signing-key-here

# ------------------------------
# M-PESA PAYMENT SETTINGS
# ------------------------------
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=your-passkey
MPESA_INITIATOR_NAME=your-initiator-name
MPESA_INITIATOR_PASSWORD=your-initiator-password

# ------------------------------
# CLOUDINARY (Image Storage)
# ------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ------------------------------
# EMAIL SETTINGS
# ------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ------------------------------
# CORS SETTINGS
# ------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://malaikanest.duckdns.org

# ------------------------------
# REDIS & CELERY
# ------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

