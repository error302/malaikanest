# ============================================
# MALAIKA NEST ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in the values

# ------------------------------
# DJANGO SETTINGS
# ------------------------------
SECRET_KEY=your-secret-key-here
ENVIRONMENT=production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,malaikanest.duckdns.org
FRONTEND_URL=https://malaikanest.duckdns.org

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/malaikanest

# ------------------------------
# JWT AUTHENTICATION
# ------------------------------
SIMPLE_JWT_SECRET=your-jwt-signing-key-here

# ------------------------------
# LOGIN LOCKOUT + CAPTCHA
# ------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=1800
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=your-turnstile-secret
CAPTCHA_ENFORCE_LOGIN=True
CAPTCHA_ENFORCE_REGISTER=True

# ------------------------------
# M-PESA PAYMENT SETTINGS
# ------------------------------
MPESA_ENV=live
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_STORE_NUMBER=3104615
MPESA_TILL_NUMBER=3370347
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://malaikanest.duckdns.org/api/payments/mpesa/callback/

# ------------------------------
# CLOUDINARY (Image Storage)
# ------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ------------------------------
# EMAIL SETTINGS
# ------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Malaika Nest <your-email@gmail.com>

# ------------------------------
# CORS + CSRF
# ------------------------------
CORS_ALLOWED_ORIGINS=https://malaikanest.duckdns.org
CSRF_TRUSTED_ORIGINS=https://malaikanest.duckdns.org

# ------------------------------
# REDIS & CELERY
# ------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
