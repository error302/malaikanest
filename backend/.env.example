# Backend Environment Configuration
# Copy to backend/.env and fill in real values before starting the server.
# NEVER commit .env files with real secrets to git.

# ─── Django Core ─────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=CHANGE_ME_GENERATE_WITH_python-c_"import_secrets;print(secrets.token_hex(50))"
SIMPLE_JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_DIFFERENT_FROM_SECRET_KEY

# ─── Allowed Hosts & CORS ────────────────────────────────────────────────────
# Comma-separated. Include your DuckDNS domain, VPS IP, and localhost for health checks.
ALLOWED_HOSTS=malaikanest.duckdns.org,www.malaikanest.duckdns.org,127.0.0.1,localhost
VPS_IP=YOUR_VPS_IP_ADDRESS
FRONTEND_URL=https://malaikanest.duckdns.org
CORS_ALLOWED_ORIGINS=https://malaikanest.duckdns.org,https://www.malaikanest.duckdns.org
CSRF_TRUSTED_ORIGINS=https://malaikanest.duckdns.org,https://www.malaikanest.duckdns.org

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Option A: individual vars
DB_NAME=malaika_production
DB_USER=malaika_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_HOST=localhost
DB_PORT=5432
# Option B: single DATABASE_URL (overrides individual vars above if set)
# DATABASE_URL=postgresql://malaika_user:CHANGE_ME@localhost:5432/malaika_production
DB_CONN_MAX_AGE=600

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# ─── Cloudinary (Media Storage) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=CHANGE_ME_YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=CHANGE_ME_YOUR_API_KEY
CLOUDINARY_API_SECRET=CHANGE_ME_YOUR_API_SECRET

# ─── Email ───────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME_YOUR_GMAIL_ADDRESS
EMAIL_HOST_PASSWORD=CHANGE_ME_YOUR_GMAIL_APP_PASSWORD
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Malaika Nest <malaikanest7@gmail.com>

# ─── M-Pesa (Daraja API) ────────────────────────────────────────────────────
# Get credentials from https://developer.safaricom.co.ke/
MPESA_ENV=sandbox
# For sandbox use: 174379 (test shortcode provided by Safaricom)
MPESA_SHORTCODE=CHANGE_ME_YOUR_SHORTCODE
MPESA_CONSUMER_KEY=CHANGE_ME_YOUR_CONSUMER_KEY
MPESA_CONSUMER_SECRET=CHANGE_ME_YOUR_CONSUMER_SECRET
# Get passkey from Daraja portal → Test Credentials → STK Push Passkey
MPESA_PASSKEY=CHANGE_ME_YOUR_PASSKEY
# Must be a publicly reachable HTTPS URL (use ngrok for local dev, your domain for prod)
MPESA_CALLBACK_URL=https://malaikanest.duckdns.org/api/v1/payments/mpesa/callback/
# Set to "production" once you go live (sandbox → production)
# MPESA_MOCK_MODE is auto-enabled in DEBUG=True mode for local dev

# ─── Admin ────────────────────────────────────────────────────────────────────
# Change this to a secret path so /manage-store/ is not guessable
ADMIN_URL_PREFIX=manage-store

# ─── Auth Cookie ─────────────────────────────────────────────────────────────
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=Strict
# AUTH_COOKIE_DOMAIN=.malaikanest.duckdns.org

# ─── Content Not Found ───────────────────────────────────────────────────────
CONTENT_NOT_FOUND_URL=/

# ─── Security (prod only) ────────────────────────────────────────────────────
# These are set automatically by config/settings/prod.py, but can be overridden:
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ─── CAPTCHA (optional) ─────────────────────────────────────────────────────
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=
CAPTCHA_TIMEOUT_SECONDS=8
CAPTCHA_ENFORCE_LOGIN=True
CAPTCHA_ENFORCE_REGISTER=True
