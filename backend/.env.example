SECRET_KEY=CHANGE_ME_WITH_50PLUS_CHAR_RANDOM_SECRET
SIMPLE_JWT_SECRET=CHANGE_ME_WITH_STRONG_JWT_SECRET

DB_ENGINE=django.db.backends.postgresql
